# Derivados regeneráveis — nunca versionar (regenerados a partir da canonica.md)
**/saidas/

# Temporários e backups
*.tmp
*.bak
*.swp
*~

# Lixo de SO
.DS_Store
Thumbs.db
desktop.ini

# Editores
.idea/
*.code-workspace

# Python / venv (ferramentas)
.venv/
__pycache__/
*.pyc
_inspecionar.py

# Referência externa de terceiros (ex.: wiki de curso pago) — local-only, não republicar
lake/**/elite-wiki/

# Conteúdo bruto no lake — pesado, não versionar (só os .md tratados entram)
# Vídeo/áudio
lake/**/*.mp4
lake/**/*.mkv
lake/**/*.mov
lake/**/*.avi
lake/**/*.mp3
lake/**/*.wav
lake/**/*.m4a
# Documentos/binários de origem (livros, slides, notas)
lake/**/*.pdf
lake/**/*.docx
lake/**/*.doc
lake/**/*.pptx
lake/**/*.ppt
lake/**/*.xlsx
lake/**/*.xls
lake/**/*.epub
lake/**/*.zip
# Imagens brutas no lake (originais pesados). As versões web finais vivem em aulas/.../img/
lake/**/*.png
lake/**/*.jpg
lake/**/*.jpeg
lake/**/*.webp
lake/**/*.gif
